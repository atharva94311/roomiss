# roomiss — environment variables
#
# Copy to .env.local and fill in. Never commit .env.local.
# The two NEXT_PUBLIC_SUPABASE_* values are safe to expose (they ride in the
# client bundle by design — RLS is what protects rows, not the key). The
# DEMO_MODE flag controls whether the "guest fresher / guest admin" shortcut
# buttons and the demo self-approve verification path are active.

# ─── Required ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-anon-key

# ─── Optional ──────────────────────────────────────────────────────────────

# "1" enables guest shortcuts + demo self-approve. Leave UNSET for prod so
# seed credentials don't ship and the demo backdoor stays closed.
NEXT_PUBLIC_DEMO_MODE=1

# Canonical site URL — used for metadataBase, OG image URLs, sitemap, robots.
# Defaults to http://localhost:3000 in dev.
# NEXT_PUBLIC_SITE_URL=https://roomiss.example.com
